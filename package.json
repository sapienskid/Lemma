  "repository": {
    "type": "git",
    "url": "https://github.com/sapienskid/neuralcard.git"
  },
  "bugs": {
    "url": "https://github.com/sapienskid/neuralcard/issues"
  },
  "homepage": "https://github.com/sapienskid/neuralcard#readme",
  "devDependencies": {
    "@types/crypto-js": "^4.2.2",
    "@types/node": "^16.11.6",
    "@typescript-eslint/eslint-plugin": "5.2.0",
    "@typescript-eslint/parser": "5.2.0",
    "builtin-modules": "3.3.0",
    "esbuild": "0.17.3",
    "obsidian": "^1.5.8",
    "tslib": "2.4.0",
    "typescript": "4.7.4"
  },
  "dependencies": {
    "@types/pouchdb": "^6.4.2",
    "chart.js": "^4.5.1",
    "crypto-js": "^4.2.0",
